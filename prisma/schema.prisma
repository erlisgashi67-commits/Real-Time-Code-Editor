// CodeSync — Real-time Collaborative Code Editor schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  avatarColor String   @default("#10b981")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedProjects Project[]       @relation("OwnedProjects")
  collaborations Collaborator[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  template    String   @default("blank")
  language    String   @default("javascript")
  isPublic    Boolean  @default(false)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User           @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  files         File[]
  versions      Version[]
  comments      Comment[]
  chatMessages  ChatMessage[]
  collaborators Collaborator[]
  shareLinks    ShareLink[]
}

model File {
  id        String   @id @default(cuid())
  projectId String
  path      String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions Version[]

  @@unique([projectId, path])
  @@index([projectId])
}

model Version {
  id         String   @id @default(cuid())
  fileId     String
  projectId  String
  content    String
  message    String   @default("Update file")
  authorName String   @default("anonymous")
  parentHash String?
  hash       String
  createdAt  DateTime @default(now())

  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([projectId])
}

model Comment {
  id         String   @id @default(cuid())
  projectId  String
  filePath   String
  lineNumber Int
  content    String
  authorName String   @default("anonymous")
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, filePath])
}

model ChatMessage {
  id         String   @id @default(cuid())
  projectId  String
  authorName String
  content    String
  system     Boolean  @default(false)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Collaborator {
  id         String   @id @default(cuid())
  projectId  String
  userId     String?
  userName   String
  permission String   @default("WRITE") // READ | WRITE | ADMIN
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // A given user account can be a collaborator on a project at most once.
  // (userId is nullable for pending email invites; SQLite treats NULLs as
  // distinct so multiple pending invites don't collide.)
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ShareLink {
  id         String   @id @default(cuid())
  projectId  String
  token      String   @unique
  permission String   @default("READ") // READ | WRITE
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
